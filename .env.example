# Server
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# Database (defaults to ./data/timetracker.db)
# DB_PATH=/app/data/timetracker.db

# Authentication mode: "local" or "oidc"
AUTH_MODE=local

# Default admin credentials (local auth only)
# If not set, a random password is generated and printed to stdout on first run
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# --- OIDC / SSO (only required when AUTH_MODE=oidc) ---
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_CLIENT_ID=clockclock
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback
# OIDC_SCOPES=openid profile email groups
# OIDC_GROUPS_CLAIM=groups
# OIDC_ADMIN_GROUP=clockclock-admins
